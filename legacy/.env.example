# Notion API credentials
NOTION_TOKEN=ntn_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instagram target
IG_USERNAME=your_instagram_username
# Set to a named collection
# Use "all-posts" only after all named collections are ingested — it is
# Instagram's catch-all view and contains every save regardless of collection.
TARGET_COLLECTION=your-collection-name

# Pipeline config
BATCH_SIZE=50
NOTION_WRITE_DELAY=0.4

# Phase 2 extraction config (optional — defaults shown)
PROCESSING_VERSION=v1.0-base
WHISPER_MODEL=base
TMP_DIR=tmp
